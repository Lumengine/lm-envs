#usda 1.0
(
    customLayerData = {
        string creator = "URDF USD Converter v0.1.3"
    }
    defaultPrim = "cartpole"
    kilogramsPerUnit = 1
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "cartpole"
{
    def Scope "Physics"
    {
        def PhysicsFixedJoint "root_joint"
        {
            rel physics:body0 = </cartpole>
            rel physics:body1 = </cartpole/Geometry/slider>
            point3f physics:localPos0 = (0, 0, 0)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
        }

        def PhysicsPrismaticJoint "slider_to_cart"
        {
            uniform token physics:axis = "Y"
            rel physics:body0 = </cartpole/Geometry/slider>
            rel physics:body1 = </cartpole/Geometry/slider/cart>
            point3f physics:localPos0 = (0, 0, 0)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            float physics:lowerLimit = -4
            float physics:upperLimit = 4
            float physxJoint:maxJointVelocity = 100
            custom float urdf:limit:effort = 1000
            custom float urdf:limit:velocity = 100
        }

        def PhysicsRevoluteJoint "cart_to_pole"
        {
            uniform token physics:axis = "X"
            rel physics:body0 = </cartpole/Geometry/slider/cart>
            rel physics:body1 = </cartpole/Geometry/slider/cart/pole>
            point3f physics:localPos0 = (0.12, 0, 0)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            # PhysxSchema units: angular maxJointVelocity is DEGREES/second.
            # 458.36624 deg/s = the URDF's 8 rad/s velocity limit.
            float physxJoint:maxJointVelocity = 458.36624
            custom float urdf:limit:effort = 1000
            custom float urdf:limit:velocity = 8
        }
    }

    over "Geometry"
    {
        over "slider" (
            prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsArticulationRootAPI", "NewtonArticulationRootAPI"]
        )
        {
            int physxArticulation:solverPositionIterationCount = 4
            int physxArticulation:solverVelocityIterationCount = 0

            over "box_1" (
                prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI"]
            )
            {
            }

            over "cart" (
                prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
            )
            {
                float physics:mass = 1
                # Inertia of the 0.2 x 0.25 x 0.2 m cart box (mass 1) about its COM.
                float3 physics:diagonalInertia = (0.00854, 0.00667, 0.00854)
                quatf physics:principalAxes = (1, 0, 0, 0)

                over "box_1" (
                    prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI"]
                )
                {
                }

                over "pole" (
                    prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
                )
                {
                    point3f physics:centerOfMass = (0, 0, 0.47)
                    float physics:mass = 1
                    # Inertia of the 0.04 x 0.06 x 1.0 m pole box (mass 1) about its COM:
                    # Ixx=Iyy=m/12*(w^2+L^2)~0.0836, Izz=m/12*(0.04^2+0.06^2)~0.00043.
                    # The converter left this unauthored (PhysX then derived a too-small
                    # inertia -> the pole fell ~2x too fast); author it to match the URDF.
                    float3 physics:diagonalInertia = (0.0836, 0.0835, 0.00043)
                    quatf physics:principalAxes = (1, 0, 0, 0)

                    over "box_1" (
                        prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI"]
                    )
                    {
                    }
                }
            }
        }
    }
}

def PhysicsScene "PhysicsScene" (
    prepend apiSchemas = ["NewtonSceneAPI"]
)
{
}
